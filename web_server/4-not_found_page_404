#!/usr/bin/env bash
# This script installs and configures Nginx on an Ubuntu machine.

# Update packages and install Nginx
sudo apt-get update
sudo apt-get install -y nginx

# Configure Nginx to return "Holberton School for the win!" on the root GET request
echo "Holberton School for the win!" | sudo tee /var/www/html/index.html

# Restart Nginx without using systemctl (using the init script directly)
sudo /etc/init.d/nginx restart
