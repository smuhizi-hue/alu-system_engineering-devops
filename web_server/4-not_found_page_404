#!/usr/bin/env bash
# Configures Nginx to serve a custom 404 error page containing "Ceci n'est pas une page"

# Update package lists and install Nginx if not already installed
sudo apt-get update -y
sudo apt-get install -y nginx

# Create the custom 404 HTML page
sudo mkdir -p /var/www/html
echo "Ceci n'est pas une page" | sudo tee /var/www/html/custom_404.html > /dev/null

# Configure Nginx default site to use the custom 404 page
CONFIG_FILE="/etc/nginx/sites-available/default"

sudo bash -c "cat << 'EOF' > $CONFIG_FILE
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    server_name _;

    # Direct 404 errors to custom_404.html
    error_page 404 /custom_404.html;
    location = /custom_404.html {
        root /var/www/html;
        internal;
    }

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF"

# Test configuration syntax and restart Nginx
sudo nginx -t && sudo systemctl restart nginx
