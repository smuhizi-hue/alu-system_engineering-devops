#!/usr/bin/env bash
# Configure a custom 404 error page on Nginx server

# Update package lists and install Nginx
sudo apt-get update -y
sudo apt-get install nginx -y

# Create the custom 404 page containing the required string
echo "Ceci n'est pas une page" | sudo tee /var/www/html/custom_404.html > /dev/null

# Insert the custom 404 error page configuration into the default Nginx site config
# This inserts the configuration right after the 'server_name _;' line
sudo sed -i '/server_name _;/a \\terror_page 404 /custom_404.html;\n\tlocation = /custom_404.html {\n\t\troot /var/www/html;\n\t\tinternal;\n\t}' /etc/nginx/sites-available/default

# Restart Nginx to apply changes
sudo service nginx restart
