#!/usr/bin/env bash
# Configures an Nginx server with a custom 404 page

# Install Nginx if not installed
sudo apt-get update -y
sudo apt-get install -y nginx

# Create custom 404 HTML file
echo "Ceci n'est pas une page" | sudo tee /usr/share/nginx/html/404.html > /dev/null

# Insert custom 404 directive inside the server block
sudo sed -i '/server_name _;/a \    error_page 404 /404.html;\n    location = /404.html {\n        root /usr/share/nginx/html;\n        internal;\n    }' /etc/nginx/sites-available/default

# Restart Nginx service
sudo service nginx restart
