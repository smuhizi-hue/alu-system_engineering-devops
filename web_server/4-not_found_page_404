#!/usr/bin/env bash
# 3-custom_404.sh
# Configures Nginx with a custom 404 error page

# Update package list and install nginx if not already installed
apt-get update -y
apt-get install -y nginx

# Make sure nginx is running
service nginx start

# Create the root index page (from previous task)
echo "Holberton School" > /var/www/html/index.html

# Create the custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/404.html

# Configure Nginx to use the custom 404 page
sed -i '/listen 80 default_server;/a\\terror_page 404 /404.html;' /etc/nginx/sites-available/default

# Restart Nginx to apply the changes
service nginx restart
