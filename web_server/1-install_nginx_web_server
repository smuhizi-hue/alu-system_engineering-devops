#!/usr/bin/env bash
# 1-install_nginx_web_server fix

# 1. Update and install Nginx
apt-get update -y
apt-get install -y nginx

# 2. Set permissions and write required string to the default root file
mkdir -p /var/www/html
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# 3. Allow Nginx through UFW firewall if active
if command -v ufw > /dev/null 2>&1; then
    ufw allow 'Nginx HTTP'
fi

# 4. Ensure Nginx configuration is valid and start service
nginx -t && service nginx restart
