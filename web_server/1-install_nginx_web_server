#!/usr/bin/env bash
# Installs an Nginx web server and configures it to return a specific string

# Update package lists
apt-get update -y

# Install Nginx
apt-get install -y nginx

# Ensure the web root directory exists
mkdir -p /var/www/html

# Write the exact string to both possible default files to be absolutely sure
echo "Holberton School for the win!" > /var/www/html/index.html
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Start the service using the traditional init.d/service management
service nginx restart
