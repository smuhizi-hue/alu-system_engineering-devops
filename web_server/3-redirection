#!/usr/bin/env bash
# Script to configure Nginx to perform a 301 redirect from /redirect_me to another URL

# Install Nginx if not already installed
apt-get update
apt-get install -y nginx

# Prepare the redirect line to insert into the default site configuration
REDIRECT_CONFIG="\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}"

# Replace the server_name line in default Nginx config with server_name and the redirect block
sed -i "/server_name _;/a \\$REDIRECT_CONFIG" /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart
